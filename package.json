{
  "name": "@rishiap/lexiform",
  "type": "module",
  "version": "0.4.12",
  "description": "Lexical-based editor as a drop-in React component and backend-safe serializers",
  "author": "RishiAP <debjyotim2019@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RishiAP/lexiform"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js",
      "require": "./dist/headless.cjs"
    },
    "./excalidraw": {
      "types": "./dist/excalidraw.d.ts",
      "import": "./dist/excalidraw.js",
      "require": "./dist/excalidraw.cjs"
    },
    "./equations": {
      "types": "./dist/equations.d.ts",
      "import": "./dist/equations.js",
      "require": "./dist/equations.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./dist/index.css": "./dist/index.css",
    "./excalidraw.css": "./dist/excalidraw.css",
    "./equations.css": "./dist/equations.css"
  },
  "typesVersions": {
    "*": {
      "headless": ["dist/headless.d.ts"],
      "excalidraw": ["dist/excalidraw.d.ts"],
      "equations": ["dist/equations.d.ts"]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "dist/**/*.css",
    "dist/**/chunk-*.js",
    "dist/**/chunk-*.cjs"
  ],
  "keywords": [
    "lexical",
    "rich-text",
    "editor",
    "react",
    "wysiwyg",
    "radix-ui"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch",
    "demo": "cd demo && npm run dev",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lexical/clipboard": "^0.45.0",
    "@lexical/code": "^0.45.0",
    "@lexical/file": "^0.45.0",
    "@lexical/hashtag": "^0.45.0",
    "@lexical/history": "^0.45.0",
    "@lexical/html": "^0.45.0",
    "@lexical/link": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/mark": "^0.45.0",
    "@lexical/markdown": "^0.45.0",
    "@lexical/overflow": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/table": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "lexical": "^0.45.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.0.0",
    "react-error-boundary": "^6.1.2"
  },
  "peerDependencies": {
    "@excalidraw/excalidraw": "*",
    "katex": "*",
    "mathlive": "*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@excalidraw/excalidraw": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "mathlive": {
      "optional": true
    }
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@lexical/headless": "^0.45.0",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "katex": "^0.17.0",
    "mathlive": "^0.110.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
